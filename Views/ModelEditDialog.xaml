<Window x:Class="BarcodePrinter.Views.ModelEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="모델 추가"
        Width="520" Height="530" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F0F2F5"
        ShowInTaskbar="False">

    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Model Name -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="모델명" FontSize="14" Foreground="#64748B" Margin="0,0,0,4"/>
            <TextBox x:Name="TbModelName" FontSize="18" Padding="10,8"
                     BorderBrush="#CBD5E1" BorderThickness="2" Background="White">
                <TextBox.Resources>
                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                </TextBox.Resources>
            </TextBox>
        </StackPanel>

        <!-- Barcode 1 + Scan -->
        <StackPanel Grid.Row="1" Margin="0,0,0,12">
            <TextBlock Text="부품 1 바코드" FontSize="14" Foreground="#64748B" Margin="0,0,0,4"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TbBarcode1" Grid.Column="0" FontSize="18" Padding="10,8"
                         BorderBrush="#CBD5E1" BorderThickness="2" Background="White">
                    <TextBox.Resources>
                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                    </TextBox.Resources>
                </TextBox>
                <Button x:Name="BtnScan1" Grid.Column="2" Content="스캔" Width="72" Height="40"
                        FontSize="15" FontWeight="SemiBold" Foreground="White" Background="#2563EB"
                        Cursor="Hand" Click="OnScanBarcode1" BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="8,4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </StackPanel>

        <!-- Barcode 2 + Scan -->
        <StackPanel Grid.Row="2" Margin="0,0,0,12">
            <TextBlock Text="부품 2 바코드" FontSize="14" Foreground="#64748B" Margin="0,0,0,4"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TbBarcode2" Grid.Column="0" FontSize="18" Padding="10,8"
                         BorderBrush="#CBD5E1" BorderThickness="2" Background="White">
                    <TextBox.Resources>
                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                    </TextBox.Resources>
                </TextBox>
                <Button x:Name="BtnScan2" Grid.Column="2" Content="스캔" Width="72" Height="40"
                        FontSize="15" FontWeight="SemiBold" Foreground="White" Background="#2563EB"
                        Cursor="Hand" Click="OnScanBarcode2" BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="8,4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </StackPanel>

        <!-- QR Data + Scan -->
        <StackPanel Grid.Row="3" Margin="0,0,0,12">
            <TextBlock Text="QR 데이터" FontSize="14" Foreground="#64748B" Margin="0,0,0,4"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TbQrData" Grid.Column="0" FontSize="18" Padding="10,8"
                         BorderBrush="#CBD5E1" BorderThickness="2" Background="White">
                    <TextBox.Resources>
                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                    </TextBox.Resources>
                </TextBox>
                <Button x:Name="BtnScanQr" Grid.Column="2" Content="스캔" Width="72" Height="40"
                        FontSize="15" FontWeight="SemiBold" Foreground="White" Background="#2563EB"
                        Cursor="Hand" Click="OnScanQrData" BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="8,4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </StackPanel>

        <!-- Scan Status -->
        <TextBlock x:Name="TbScanStatus" Grid.Row="4" FontSize="14" Foreground="#94A3B8"
                   HorizontalAlignment="Center" Margin="0,0,0,8"/>

        <!-- Buttons -->
        <Grid Grid.Row="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="취소" Height="48" FontSize="17" FontWeight="SemiBold"
                    Foreground="White" Background="#64748B" Cursor="Hand"
                    Click="OnCancel" BorderThickness="0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="10,8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Grid.Column="2" Content="추가" Height="48" FontSize="17" FontWeight="SemiBold"
                    Foreground="White" Background="#2563EB" Cursor="Hand"
                    Click="OnConfirm" BorderThickness="0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="10,8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
    </Grid>
</Window>
