<Window x:Class="BarcodePrinter.Views.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="장치 설정"
        Width="520" Height="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F0F2F5"
        ShowInTaskbar="False">

    <Grid Margin="20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Margin="0,0,0,12">
            <StackPanel>

                <!-- ===== PLC (Modbus TCP) ===== -->
                <Border Background="White" CornerRadius="10" Padding="18,14" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="PLC (Modbus TCP)" FontSize="17" FontWeight="Bold"
                                   Foreground="#1E293B" Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- IP / Port -->
                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,8">
                                <TextBlock Text="IP 주소" FontSize="12" Foreground="#64748B" Margin="0,0,0,3"/>
                                <TextBox x:Name="TbPlcIp" FontSize="15" Padding="8,6"
                                         BorderBrush="#CBD5E1" BorderThickness="1.5" Background="White">
                                    <TextBox.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></TextBox.Resources>
                                </TextBox>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,8">
                                <TextBlock Text="포트" FontSize="12" Foreground="#64748B" Margin="0,0,0,3"/>
                                <TextBox x:Name="TbPlcPort" FontSize="15" Padding="8,6"
                                         BorderBrush="#CBD5E1" BorderThickness="1.5" Background="White">
                                    <TextBox.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></TextBox.Resources>
                                </TextBox>
                            </StackPanel>

                            <!-- Slave ID / Polling -->
                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,8">
                                <TextBlock Text="Slave ID" FontSize="12" Foreground="#64748B" Margin="0,0,0,3"/>
                                <TextBox x:Name="TbPlcSlaveId" FontSize="15" Padding="8,6"
                                         BorderBrush="#CBD5E1" BorderThickness="1.5" Background="White">
                                    <TextBox.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></TextBox.Resources>
                                </TextBox>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,8">
                                <TextBlock Text="폴링(ms)" FontSize="12" Foreground="#64748B" Margin="0,0,0,3"/>
                                <TextBox x:Name="TbPlcPolling" FontSize="15" Padding="8,6"
                                         BorderBrush="#CBD5E1" BorderThickness="1.5" Background="White">
                                    <TextBox.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></TextBox.Resources>
                                </TextBox>
                            </StackPanel>

                            <!-- Registers -->
                            <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,8">
                                <TextBlock Text="레지스터 주소 (결과 / 출력트리거 / 출력완료)" FontSize="12" Foreground="#64748B" Margin="0,0,0,3"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/><ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/><ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="TbPlcResultReg" Grid.Column="0" FontSize="15" Padding="8,6"
                                             BorderBrush="#CBD5E1" BorderThickness="1.5" Background="White">
                                        <TextBox.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></TextBox.Resources>
                                    </TextBox>
                                    <TextBox x:Name="TbPlcTriggerReg" Grid.Column="2" FontSize="15" Padding="8,6"
                                             BorderBrush="#CBD5E1" BorderThickness="1.5" Background="White">
                                        <TextBox.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></TextBox.Resources>
                                    </TextBox>
                                    <TextBox x:Name="TbPlcCompleteReg" Grid.Column="4" FontSize="15" Padding="8,6"
                                             BorderBrush="#CBD5E1" BorderThickness="1.5" Background="White">
                                        <TextBox.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></TextBox.Resources>
                                    </TextBox>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ===== Serial Barcode Reader ===== -->
                <Border Background="White" CornerRadius="10" Padding="18,14" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="바코드 리더 (Serial)" FontSize="17" FontWeight="Bold"
                                   Foreground="#1E293B" Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,8">
                                <TextBlock Text="COM 포트" FontSize="12" Foreground="#64748B" Margin="0,0,0,3"/>
                                <TextBox x:Name="TbSerialPort" FontSize="15" Padding="8,6"
                                         BorderBrush="#CBD5E1" BorderThickness="1.5" Background="White">
                                    <TextBox.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></TextBox.Resources>
                                </TextBox>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,8">
                                <TextBlock Text="Baud Rate" FontSize="12" Foreground="#64748B" Margin="0,0,0,3"/>
                                <TextBox x:Name="TbSerialBaud" FontSize="15" Padding="8,6"
                                         BorderBrush="#CBD5E1" BorderThickness="1.5" Background="White">
                                    <TextBox.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></TextBox.Resources>
                                </TextBox>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,0">
                                <TextBlock Text="Data Bits / Parity / Stop Bits" FontSize="12" Foreground="#64748B" Margin="0,0,0,3"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/><ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/><ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="TbSerialDataBits" Grid.Column="0" FontSize="15" Padding="8,6"
                                             BorderBrush="#CBD5E1" BorderThickness="1.5" Background="White">
                                        <TextBox.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></TextBox.Resources>
                                    </TextBox>
                                    <TextBox x:Name="TbSerialParity" Grid.Column="2" FontSize="15" Padding="8,6"
                                             BorderBrush="#CBD5E1" BorderThickness="1.5" Background="White">
                                        <TextBox.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></TextBox.Resources>
                                    </TextBox>
                                    <TextBox x:Name="TbSerialStopBits" Grid.Column="4" FontSize="15" Padding="8,6"
                                             BorderBrush="#CBD5E1" BorderThickness="1.5" Background="White">
                                        <TextBox.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></TextBox.Resources>
                                    </TextBox>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ===== Zebra Printer ===== -->
                <Border Background="White" CornerRadius="10" Padding="18,14">
                    <StackPanel>
                        <TextBlock Text="프린터 (Zebra ZPL)" FontSize="17" FontWeight="Bold"
                                   Foreground="#1E293B" Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,8">
                                <TextBlock Text="IP 주소" FontSize="12" Foreground="#64748B" Margin="0,0,0,3"/>
                                <TextBox x:Name="TbPrnIp" FontSize="15" Padding="8,6"
                                         BorderBrush="#CBD5E1" BorderThickness="1.5" Background="White">
                                    <TextBox.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></TextBox.Resources>
                                </TextBox>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,8">
                                <TextBlock Text="포트" FontSize="12" Foreground="#64748B" Margin="0,0,0,3"/>
                                <TextBox x:Name="TbPrnPort" FontSize="15" Padding="8,6"
                                         BorderBrush="#CBD5E1" BorderThickness="1.5" Background="White">
                                    <TextBox.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></TextBox.Resources>
                                </TextBox>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,0">
                                <TextBlock Text="QR 배율 / Origin X / Origin Y" FontSize="12" Foreground="#64748B" Margin="0,0,0,3"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/><ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/><ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="TbPrnQrMag" Grid.Column="0" FontSize="15" Padding="8,6"
                                             BorderBrush="#CBD5E1" BorderThickness="1.5" Background="White">
                                        <TextBox.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></TextBox.Resources>
                                    </TextBox>
                                    <TextBox x:Name="TbPrnOriginX" Grid.Column="2" FontSize="15" Padding="8,6"
                                             BorderBrush="#CBD5E1" BorderThickness="1.5" Background="White">
                                        <TextBox.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></TextBox.Resources>
                                    </TextBox>
                                    <TextBox x:Name="TbPrnOriginY" Grid.Column="4" FontSize="15" Padding="8,6"
                                             BorderBrush="#CBD5E1" BorderThickness="1.5" Background="White">
                                        <TextBox.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></TextBox.Resources>
                                    </TextBox>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="취소" Height="48" FontSize="17" FontWeight="SemiBold"
                    Foreground="White" Background="#64748B" Cursor="Hand"
                    Click="OnCancel" BorderThickness="0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="10,8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Grid.Column="2" Content="저장" Height="48" FontSize="17" FontWeight="SemiBold"
                    Foreground="White" Background="#2563EB" Cursor="Hand"
                    Click="OnSave" BorderThickness="0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="10,8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
    </Grid>
</Window>
