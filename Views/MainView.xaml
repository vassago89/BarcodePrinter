<Window x:Class="BarcodePrinter.Views.MainView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:BarcodePrinter.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        mc:Ignorable="d"
        Title="바코드 검증 / QR 출력 시스템"
        Width="1024" Height="768"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F0F2F5">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="58"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="44"/>
        </Grid.RowDefinitions>

        <!-- ==================== HEADER ==================== -->
        <Border Grid.Row="0" Background="#1E293B">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="바코드 검증 / QR 출력"
                           FontSize="22" FontWeight="Bold"
                           Foreground="White" VerticalAlignment="Center"/>

                <!-- Connect / Disconnect / Settings -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,14,0">
                    <Button Content="설정" Command="{Binding OpenSettingsCommand}"
                            Width="70" Height="36" FontSize="14" FontWeight="Bold" Margin="0,0,6,0"
                            Foreground="White" Background="#8B5CF6" BorderThickness="0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="8,4">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Content="연결" Command="{Binding ConnectAllCommand}"
                            IsEnabled="{Binding IsConnecting, Converter={StaticResource InverseBoolConverter}}"
                            Width="70" Height="36" FontSize="14" FontWeight="Bold"
                            Foreground="White" Background="#2563EB" BorderThickness="0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="8,4">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Content="해제" Command="{Binding DisconnectAllCommand}"
                            Width="70" Height="36" FontSize="14" FontWeight="Bold" Margin="6,0,0,0"
                            Foreground="White" Background="#64748B" BorderThickness="0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="8,4">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

                <!-- Connection Indicators -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border CornerRadius="14" Padding="10,5" Margin="4,0"
                            Background="{Binding IsPlcConnected, Converter={StaticResource BoolToColorConverter}}">
                        <TextBlock Text="PLC" FontSize="12" Foreground="White" FontWeight="Bold"/>
                    </Border>
                    <Border CornerRadius="14" Padding="10,5" Margin="4,0"
                            Background="{Binding IsReaderConnected, Converter={StaticResource BoolToColorConverter}}">
                        <TextBlock Text="RDR" FontSize="12" Foreground="White" FontWeight="Bold"/>
                    </Border>
                    <Border CornerRadius="14" Padding="10,5" Margin="4,0"
                            Background="{Binding IsPrinterConnected, Converter={StaticResource BoolToColorConverter}}">
                        <TextBlock Text="PRN" FontSize="12" Foreground="White" FontWeight="Bold"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ==================== CONTENT ==================== -->
        <Grid Grid.Row="1" Margin="12,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ===== LEFT: Model List ===== -->
            <Border Grid.Column="0" Background="White" CornerRadius="12"
                    Effect="{StaticResource CardShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="모델 선택"
                               FontSize="17" FontWeight="Bold" Foreground="#1E293B"
                               Margin="16,14,16,10"/>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding ModelNames}"
                             SelectedItem="{Binding SelectedModelName}"
                             BorderThickness="0" Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             Margin="6,0,6,0">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="14,12"/>
                                <Setter Property="Margin" Value="2,2"/>
                                <Setter Property="FontSize" Value="17"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Foreground" Value="#334155"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd" CornerRadius="10"
                                                    Background="#F8FAFC"
                                                    Padding="{TemplateBinding Padding}"
                                                    Margin="{TemplateBinding Margin}">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#2563EB"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </Trigger>
                                                <MultiTrigger>
                                                    <MultiTrigger.Conditions>
                                                        <Condition Property="IsMouseOver" Value="True"/>
                                                        <Condition Property="IsSelected" Value="False"/>
                                                    </MultiTrigger.Conditions>
                                                    <Setter TargetName="Bd" Property="Background" Value="#E2E8F0"/>
                                                </MultiTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>

                    <!-- Add / Delete Buttons -->
                    <Grid Grid.Row="2" Margin="10,6,10,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="추가"
                                Command="{Binding AddModelCommand}"
                                Style="{StaticResource TouchButtonPrimary}"
                                Height="42" FontSize="15"/>
                        <Button Grid.Column="2" Content="삭제"
                                Command="{Binding DeleteModelCommand}"
                                Style="{StaticResource TouchButtonDanger}"
                                Height="42" FontSize="15"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- ===== RIGHT: Scan + QR ===== -->
            <Border Grid.Column="2" Background="White" CornerRadius="12"
                    Effect="{StaticResource CardShadow}">
                <Grid Margin="22,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Selected Model Title -->
                    <TextBlock Grid.Row="0" Grid.ColumnSpan="3"
                               FontSize="20" FontWeight="Bold" Foreground="#1E293B"
                               Margin="0,0,0,14">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="{Binding SelectedModelName, StringFormat='모델: {0}'}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedModelName}" Value="{x:Null}">
                                        <Setter Property="Text" Value="모델을 선택하세요"/>
                                        <Setter Property="Foreground" Value="#94A3B8"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Part 1 Barcode -->
                    <Border Grid.Row="1" Grid.Column="0" CornerRadius="10"
                            Padding="14,8" Margin="0,0,0,10" MinHeight="62"
                            BorderThickness="2">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#F8FAFC"/>
                                <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsBarcode1Scanned}" Value="True"/>
                                            <Condition Binding="{Binding IsBarcode1Match}" Value="True"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="BorderBrush" Value="#16A34A"/>
                                        <Setter Property="Background" Value="#F0FDF4"/>
                                    </MultiDataTrigger>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsBarcode1Scanned}" Value="True"/>
                                            <Condition Binding="{Binding IsBarcode1Match}" Value="False"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="BorderBrush" Value="#DC2626"/>
                                        <Setter Property="Background" Value="#FEF2F2"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,3">
                                <TextBlock FontSize="12" Foreground="#94A3B8" Text="부품 1"/>
                                <TextBlock FontSize="12" Foreground="#64748B" Margin="8,0,0,0"
                                           Visibility="{Binding ExpectedBarcode1, Converter={StaticResource StringToVisibilityConverter}}"
                                           Text="{Binding ExpectedBarcode1, StringFormat='(예상: {0})'}"/>
                            </StackPanel>
                            <TextBlock Grid.Row="1" FontSize="20" FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="{Binding Barcode1}"/>
                                        <Setter Property="Foreground" Value="#1E293B"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Barcode1}" Value="">
                                                <Setter Property="Text" Value="(스캔 대기)"/>
                                                <Setter Property="Foreground" Value="#CBD5E1"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <!-- Part 2 Barcode -->
                    <Border Grid.Row="2" Grid.Column="0" CornerRadius="10"
                            Padding="14,8" Margin="0,0,0,10" MinHeight="62"
                            BorderThickness="2">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#F8FAFC"/>
                                <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsBarcode2Scanned}" Value="True"/>
                                            <Condition Binding="{Binding IsBarcode2Match}" Value="True"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="BorderBrush" Value="#16A34A"/>
                                        <Setter Property="Background" Value="#F0FDF4"/>
                                    </MultiDataTrigger>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsBarcode2Scanned}" Value="True"/>
                                            <Condition Binding="{Binding IsBarcode2Match}" Value="False"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="BorderBrush" Value="#DC2626"/>
                                        <Setter Property="Background" Value="#FEF2F2"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,3">
                                <TextBlock FontSize="12" Foreground="#94A3B8" Text="부품 2"/>
                                <TextBlock FontSize="12" Foreground="#64748B" Margin="8,0,0,0"
                                           Visibility="{Binding ExpectedBarcode2, Converter={StaticResource StringToVisibilityConverter}}"
                                           Text="{Binding ExpectedBarcode2, StringFormat='(예상: {0})'}"/>
                            </StackPanel>
                            <TextBlock Grid.Row="1" FontSize="20" FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="{Binding Barcode2}"/>
                                        <Setter Property="Foreground" Value="#1E293B"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Barcode2}" Value="">
                                                <Setter Property="Text" Value="(스캔 대기)"/>
                                                <Setter Property="Foreground" Value="#CBD5E1"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <!-- QR Code Preview (right side) -->
                    <Border Grid.Row="1" Grid.RowSpan="2" Grid.Column="2"
                            Background="#F8FAFC" CornerRadius="10"
                            Width="220" Height="220"
                            BorderBrush="#E2E8F0" BorderThickness="1"
                            VerticalAlignment="Top" Margin="0,0,0,10">
                        <Grid>
                            <TextBlock Text="QR" FontSize="36" Foreground="#E2E8F0"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding QrImage}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <Image Source="{Binding QrImage}"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor"
                                   Stretch="Uniform" MaxWidth="200" MaxHeight="200"
                                   Margin="10"/>
                        </Grid>
                    </Border>

                    <!-- Result Display -->
                    <Border Grid.Row="3" Grid.ColumnSpan="3" CornerRadius="14"
                            VerticalAlignment="Center" HorizontalAlignment="Stretch"
                            Padding="20,16"
                            Background="{Binding ComparisonResult, Converter={StaticResource ResultToColorConverter}}"
                            Visibility="{Binding ComparisonResult, Converter={StaticResource StringToVisibilityConverter}}">
                        <TextBlock Text="{Binding ComparisonResult}"
                                   FontSize="56" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center"/>
                    </Border>

                    <!-- Bottom Buttons -->
                    <Grid Grid.Row="4" Grid.ColumnSpan="3" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" Content="초기화"
                                Command="{Binding ResetCommand}"
                                Style="{StaticResource TouchButtonSecondary}"
                                Height="52" FontSize="18"/>
                        <Button Grid.Column="2" Content="수동 출력"
                                Command="{Binding ManualPrintCommand}"
                                Style="{StaticResource TouchButtonSuccess}"
                                Height="52" FontSize="18"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- ==================== STATUS BAR ==================== -->
        <Border Grid.Row="2" Background="#1E293B">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="14" Foreground="#94A3B8"
                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>

                <Border Grid.Column="1" CornerRadius="5" Padding="10,3" Background="#334155"
                        VerticalAlignment="Center">
                    <TextBlock FontSize="13" Foreground="#94A3B8">
                        <Run Text="{Binding StateDisplay, Mode=OneWay}" Foreground="#E2E8F0"/>
                    </TextBlock>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
